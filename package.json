{
  "name": "@fielding/chopz",
  "version": "0.4.1",
  "description": "A safety-first layer over the skills CLI: named bundles and safe same-repo dependency resolution for agent skills.",
  "type": "module",
  "bin": {
    "chopz": "bin/chopz.js"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "bin",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
